# Normalize text files to LF
*.csv text eol=lf
*.py text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.svg text eol=lf
*.keras binary
*.h5 binary